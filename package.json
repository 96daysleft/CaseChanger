{
  "name": "vscode-case-changer-context",
  "displayName": "Case Changer Context Menu",
  "description": "Change the case of text using cmds or context menu",
  "version": "1.4.0",
  "icon": "images/logo.png",
  "galleryBanner": {
    "color": "#110580",
    "theme": "dark"
  },
  "publisher": "jerky676",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jerky676/CaseChanger"
  },
  "engines": {
    "vscode": "^1.79.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension",
  "contributes": {
    "commands": [
      {
        "command": "extension.caseChanger.upper",
        "title": "Change to UPPER CASE"
      },
      {
        "command": "extension.caseChanger.lower",
        "title": "Change to lower case"
      },
      {
        "command": "extension.caseChanger.camel",
        "title": "Change to camelCase"
      },
      {
        "command": "extension.caseChanger.kebab",
        "title": "Change to kebab-case"
      },
      {
        "command": "extension.caseChanger.pascal",
        "title": "Change to PascalCase"
      },
      {
        "command": "extension.caseChanger.capital",
        "title": "Change to Capital Case"
      },
      {
        "command": "extension.caseChanger.constant",
        "title": "Change to CONST_CASE"
      },
      {
        "command": "extension.caseChanger.dot",
        "title": "Change to dot.case"
      },
      {
        "command": "extension.caseChanger.none",
        "title": "Change to no case"
      },
      {
        "command": "extension.caseChanger.sentence",
        "title": "Change to Sentence case"
      },
      {
        "command": "extension.caseChanger.snake",
        "title": "Change to snake_case"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "caseChanger.case",
          "group": "3_modification",
          "when": "editorHasSelection"
        }
      ],
      "caseChanger.case": [
        {
          "command": "extension.caseChanger.upper",
          "group": "1_caseChanger"
        },
        {
          "command": "extension.caseChanger.lower",
          "group": "1_caseChanger"
        },
        {
          "command": "extension.caseChanger.camel",
          "group": "1_caseChanger"
        },
        {
          "command": "extension.caseChanger.kebab",
          "group": "1_caseChanger"
        },
        {
          "command": "extension.caseChanger.pascal",
          "group": "1_caseChanger"
        },
        {
          "command": "extension.caseChanger.capital",
          "group": "1_caseChanger"
        },
        {
          "command": "extension.caseChanger.constant",
          "group": "1_caseChanger"
        },
        {
          "command": "extension.caseChanger.dot",
          "group": "1_caseChanger"
        },
        {
          "command": "extension.caseChanger.none",
          "group": "1_caseChanger"
        },
        {
          "command": "extension.caseChanger.sentence",
          "group": "1_caseChanger"
        },
        {
          "command": "extension.caseChanger.snake",
          "group": "1_caseChanger"
        }
      ]
    },
    "submenus": [
      {
        "id": "caseChanger.case",
        "label": "Change Case"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run compile && node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/assert": "^1.5.11",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/test-electron": "^2.4.1",
    "chai": "^5.1.2",
    "glob": "^11.0.0",
    "minimatch": "^10.0.1",
    "mocha": "^11.0.1",
    "typescript": "^5.7.2",
    "vscode-test": "^1.6.1"
  },
  "dependencies": {
    "change-case": "^4.1.2"
  }
}
